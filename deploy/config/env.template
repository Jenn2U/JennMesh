# JennMesh Environment Configuration
# Copy to /etc/jenn-mesh/env and fill in values
# Used by all jenn-mesh-* systemd services

# ── Database ──────────────────────────────────────────────────────
JENN_MESH_DB_PATH=/var/lib/jenn-mesh/mesh.db

# ── MQTT Broker ───────────────────────────────────────────────────
MQTT_BROKER=127.0.0.1
MQTT_PORT=1884
MQTT_USERNAME=jenn-mesh
MQTT_PASSWORD=changeme

# ── Agent ─────────────────────────────────────────────────────────
# Serial port for Meshtastic radio (auto = auto-detect /dev/meshtastic*)
MESHTASTIC_PORT=auto
# LoRa region used in MQTT topic namespace
LORA_REGION=US

# ── Dashboard ─────────────────────────────────────────────────────
# Leave empty for LAN-only (no reverse proxy)
ROOT_PATH=
# Bind address and port (also set in systemd ExecStart)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8002

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── JennSentry Agent (sidecar) ────────────────────────────────────
JENN_SENTRY_DASHBOARD_URL=https://sentry.jenn2u.ai
JENN_SENTRY_AGENT_DB_PATH=/var/lib/jenn-mesh/sentry-agent.db
JENN_SENTRY_AGENT_PID_FILE=/var/lib/jenn-mesh/sentry-agent.pid
JENN_SENTRY_AGENT_MONITOR_URL=http://127.0.0.1:8002/health

# ── CrewAI Agent Orchestration ──────────────────────────────────────
# Set to true to enable multi-agent crew orchestration (requires crewai package)
CREWAI_ENABLED=false
# LLM model for crew agents (must be accessible via Ollama or LiteLLM)
CREWAI_LLM_MODEL=ollama/qwen3:4b
# Enable verbose logging for crew execution debugging
CREWAI_VERBOSE=false
